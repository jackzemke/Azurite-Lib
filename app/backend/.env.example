# Azurite Archive Assistant - Environment Configuration
# Copy this file to .env and fill in your values.
# Environment variables override config.yaml values.
# All variables use the AAA_ prefix.

# Base directory (project root). All relative paths resolve from here.
# AAA_BASE_DIR=/home/your-user/lib/project-library

# --- ODBC (HDP driver → Ajera SQL) ---
# DSN name must match the [section] in the HDP odbc.ini
AAA_DB_DSN=AjeraHDP
# Leave blank if credentials are baked into the DSN:
AAA_DB_USERNAME=
AAA_DB_PASSWORD=

# --- Ajera REST API (used only for employee names via ListEmployees v1) ---
# API URL with base64-encoded config (from Ajera: Utility > Setup Integrations > API Settings)
# AAA_AJERA_API_URL=https://ajera.com/V004864/AjeraAPI.ashx?ew0KICAi...
# AAA_AJERA_API_USERNAME=
# AAA_AJERA_API_PASSWORD=
# Sync interval in hours (0 = disabled, manual trigger only)
# AAA_AJERA_SYNC_INTERVAL_HOURS=0

# --- Model overrides ---
# AAA_MODEL_PATH=data/models/Meta-Llama-3.1-8B-Instruct-Q6_K.gguf
# AAA_MODEL_N_GPU_LAYERS=40
# AAA_MODEL_N_THREADS=8
# AAA_MODEL_MAX_TOKENS=1024
# AAA_MODEL_N_CTX=8192

# --- Ollama fallback (used when no local GGUF model is available) ---
# AAA_OLLAMA_URL=http://localhost:11434
# AAA_OLLAMA_MODEL=llama3.2:3b

# --- Embedding model ---
# AAA_EMBEDDING_MODEL_NAME=nomic-ai/nomic-embed-text-v1.5
# AAA_EMBEDDING_BATCH_SIZE=32

# --- Security ---
# Set an API key to require authentication (X-API-Key header).
# Leave empty for open access (dev mode).
# AAA_API_KEY=
# Frontend URL for CORS. Set to your deployed frontend origin in production.
# AAA_FRONTEND_URL=http://localhost:5173

# --- Path overrides (relative to base_dir, or absolute) ---
# AAA_RAW_DOCS_DIR=data/raw_docs
# AAA_CHROMA_DB_DIR=data/index/chroma

# --- Debug ---
# AAA_DEBUG_MODE=false
